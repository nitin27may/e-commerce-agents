# ============================================================
# E-Commerce Agents — Environment Configuration
# ============================================================
# Copy to .env and configure your LLM provider:
#   cp .env.example .env
#
# Two LLM providers are supported. Uncomment ONE section below.
# All agents, tools, and embedding generation use the same provider.
# ============================================================


# ── LLM Provider ─────────────────────────────────────────────
# Set to "openai" or "azure" — controls ALL LLM and embedding calls
LLM_PROVIDER=openai


# ┌────────────────────────────────────────────────────────────┐
# │  OPTION A: OpenAI                                          │
# │  Set LLM_PROVIDER=openai and fill in below                 │
# └────────────────────────────────────────────────────────────┘

OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-small


# ┌────────────────────────────────────────────────────────────┐
# │  OPTION B: Azure OpenAI                                    │
# │  Set LLM_PROVIDER=azure and fill in below                  │
# └────────────────────────────────────────────────────────────┘

# LLM_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Azure embedding deployment (uses EMBEDDING_MODEL name if not set)
AZURE_EMBEDDING_DEPLOYMENT=


# ── Database ─────────────────────────────────────────────────
# Use @localhost here. docker-compose.yml hardcodes its own DATABASE_URL
# (with @db) for in-container services, so this value is only consumed
# by host-side scripts: evals, seeders, and local REPL sessions.
POSTGRES_DB=ecommerce_agents
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce_secret
DATABASE_URL=postgresql://ecommerce:ecommerce_secret@localhost:5432/ecommerce_agents


# ── Redis ────────────────────────────────────────────────────
# Same as DATABASE_URL — host-side scripts use localhost, containers use redis.
REDIS_URL=redis://localhost:6379


# ── Auth ─────────────────────────────────────────────────────
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-random-256-bit-key
AGENT_SHARED_SECRET=agent-internal-shared-secret


# ── Telemetry (OpenTelemetry → .NET Aspire Dashboard) ────────
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://aspire:18889
OTEL_SERVICE_NAME=ecommerce.orchestrator


# ── General ──────────────────────────────────────────────────
ENVIRONMENT=development


# ── Agent Registry ───────────────────────────────────────────
# Internal Docker network URLs for inter-agent A2A communication
AGENT_REGISTRY={"product-discovery":"http://product-discovery:8081","order-management":"http://order-management:8082","pricing-promotions":"http://pricing-promotions:8083","review-sentiment":"http://review-sentiment:8084","inventory-fulfillment":"http://inventory-fulfillment:8085"}


# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
